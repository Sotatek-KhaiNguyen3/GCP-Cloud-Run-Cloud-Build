# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=cloudrun-zero2prod
APP_VERSION=1.0.0
BUILD_TIME=2026-01-01T00:00:00Z
PORT=8080

# ── Database (local dev) ─────────────────────────────────────────────────────
# Dùng khi chạy local với PostgreSQL hoặc cloud-sql-proxy
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zero2prod
DB_USER=app_user
DB_PASSWORD=your_password_here

# ── Database (Cloud Run) ─────────────────────────────────────────────────────
# Tự động set bởi --add-cloudsql-instances khi deploy Cloud Run
# Không cần set thủ công khi chạy trên Cloud Run
# INSTANCE_CONNECTION_NAME=PROJECT_ID:asia-southeast1:cloudrun-zero2prod-db
